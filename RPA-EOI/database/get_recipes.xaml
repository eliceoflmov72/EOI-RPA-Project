    <ui:InvokeCode ContinueOnError="{x:Null}" Code="try&#xD;&#xA;{&#xD;&#xA;    var client = new MongoDB.Driver.MongoClient(connectionString);&#xD;&#xA;    var database = client.GetDatabase(&quot;robocheff&quot;);&#xD;&#xA;    var collection = database.GetCollection&lt;MongoDB.Bson.BsonDocument&gt;(&quot;recetas&quot;);&#xD;&#xA;&#xD;&#xA;    // Filtro vacío&#xD;&#xA;    var emptyFilter = MongoDB.Driver.FilterDefinition&lt;MongoDB.Bson.BsonDocument&gt;.Empty;&#xD;&#xA;&#xD;&#xA;    // FindSync síncrono&#xD;&#xA;    var cursor = collection.FindSync&lt;MongoDB.Bson.BsonDocument&gt;(emptyFilter);&#xD;&#xA;&#xD;&#xA;    // Iterar manualmente el cursor (la forma más segura en Invoke Code)&#xD;&#xA;    var documentos = new System.Collections.Generic.List&lt;MongoDB.Bson.BsonDocument&gt;();&#xD;&#xA;&#xD;&#xA;    while (cursor.MoveNext())&#xD;&#xA;    {&#xD;&#xA;        foreach (var doc in cursor.Current)&#xD;&#xA;        {&#xD;&#xA;            documentos.Add(doc);&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;listaRecetas = new System.Collections.Generic.List&lt;string&gt;();&#xD;&#xA;&#xD;&#xA;    if (documentos.Count == 0)&#xD;&#xA;    {&#xD;&#xA;        listaRecetas.Add(&quot;No hay recetas guardadas aún en la base de datos 'robocheff'.&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        int numeroReceta = 1;&#xD;&#xA;        foreach (var doc in documentos)&#xD;&#xA;        {&#xD;&#xA;            string caracteristicas = doc.GetValue(&quot;caracteristicas&quot;, &quot;Sin descripción&quot;).AsString;&#xD;&#xA;&#xD;&#xA;            var ingredientesArray = doc.GetValue(&quot;ingredientes&quot;, new MongoDB.Bson.BsonArray()).AsBsonArray;&#xD;&#xA;            var listaIngredientes = new System.Collections.Generic.List&lt;string&gt;();&#xD;&#xA;&#xD;&#xA;            foreach (var ing in ingredientesArray)&#xD;&#xA;            {&#xD;&#xA;                string cantidad = ing.AsBsonDocument.GetValue(&quot;cantidad&quot;, &quot;&quot;).AsString;&#xD;&#xA;                string ingrediente = ing.AsBsonDocument.GetValue(&quot;ingrediente&quot;, &quot;&quot;).AsString;&#xD;&#xA;                string linea = (cantidad.Trim() + &quot; &quot; + ingrediente.Trim()).Trim();&#xD;&#xA;                if (!string.IsNullOrWhiteSpace(linea))&#xD;&#xA;                {&#xD;&#xA;                    listaIngredientes.Add(&quot;• &quot; + linea);&#xD;&#xA;                }&#xD;&#xA;            }&#xD;&#xA;&#xD;&#xA;            string recetaTexto = &quot;--- RECETA &quot; + numeroReceta.ToString() + &quot; ---\n&quot; +&#xD;&#xA;                                 &quot;Descripción:\n&quot; + caracteristicas.Trim() + &quot;\n\n&quot; +&#xD;&#xA;                                 &quot;Ingredientes:\n&quot; + string.Join(&quot;\n&quot;, listaIngredientes);&#xD;&#xA;&#xD;&#xA;            if (doc.Contains(&quot;fechaGuardado&quot;))&#xD;&#xA;            {&#xD;&#xA;                var fecha = doc[&quot;fechaGuardado&quot;].ToUniversalTime();&#xD;&#xA;                recetaTexto = recetaTexto + &quot;\nGuardada el: &quot; + fecha.ToString(&quot;yyyy-MM-dd HH:mm&quot;) + &quot; UTC&quot;;&#xD;&#xA;            }&#xD;&#xA;&#xD;&#xA;            recetaTexto = recetaTexto + &quot;\n&quot;;&#xD;&#xA;&#xD;&#xA;            listaRecetas.Add(recetaTexto);&#xD;&#xA;            numeroReceta++;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    System.Console.WriteLine(&quot;¡Se leyeron &quot; + documentos.Count.ToString() + &quot; recetas correctamente de MongoDB!&quot;);&#xD;&#xA;}&#xD;&#xA;catch (System.Exception ex)&#xD;&#xA;{&#xD;&#xA;    throw new System.Exception(&quot;Error al leer las recetas de MongoDB: &quot; + ex.Message);&#xD;&#xA;}" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="450,188" sap2010:WorkflowViewState.IdRef="InvokeCode_3" Language="CSharp">
